{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/render-manifest.schema.json",
  "title": "RenderManifest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "job_id": {
      "type": "string",
      "minLength": 3
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "voice_profile": {
      "type": "string",
      "minLength": 1
    },
    "renderer": {
      "type": "string",
      "enum": ["fake", "voicelayer-qwen3", "external-command"]
    },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "script": {
            "type": "string",
            "minLength": 1
          },
          "audio_path": {
            "type": "string"
          },
          "duration_seconds": {
            "type": "number",
            "minimum": 0
          },
          "words_path": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "rendered", "failed", "skipped"]
          },
          "error": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["id", "title", "script", "audio_path", "duration_seconds", "words_path", "status"]
      }
    },
    "total_duration_seconds": {
      "type": "number",
      "minimum": 0
    },
    "artifacts_dir": {
      "type": "string",
      "minLength": 1
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["job_id", "created_at", "voice_profile", "renderer", "segments", "total_duration_seconds", "artifacts_dir", "errors"]
}
