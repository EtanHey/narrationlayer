{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/words.schema.json",
  "title": "Words",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "job_id": {
      "type": "string",
      "minLength": 3
    },
    "segment_id": {
      "type": "string",
      "minLength": 1
    },
    "words": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "index": {
            "type": "number",
            "minimum": 0
          },
          "word": {
            "type": "string",
            "minLength": 1
          },
          "start_seconds": {
            "type": "number",
            "minimum": 0
          },
          "end_seconds": {
            "type": "number",
            "minimum": 0
          }
        },
        "required": ["index", "word", "start_seconds", "end_seconds"]
      }
    }
  },
  "required": ["job_id", "segment_id", "words"]
}
