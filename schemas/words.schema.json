{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/words.schema.json",
  "title": "Words",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "job_id": {
      "type": "string",
      "minLength": 3
    },
    "segment_id": {
      "type": "string",
      "minLength": 1
    },
    "words": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "index": {
            "type": "number",
            "minimum": 0
          },
          "word": {
            "type": "string",
            "minLength": 1
          },
          "start": {
            "type": "number",
            "minimum": 0
          },
          "end": {
            "type": "number",
            "minimum": 0
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": ["index", "word", "start", "end"]
      }
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["available", "unavailable"]
        },
        "source": {
          "type": "string",
          "enum": ["fake", "voicelayer-qwen3", "whisper-cli", "estimated"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["status", "source"]
    }
  },
  "required": ["job_id", "segment_id", "timing", "words"]
}
