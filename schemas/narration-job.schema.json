{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/narration-job.schema.json",
  "title": "NarrationJob",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "job_id": {
      "type": "string",
      "minLength": 3,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "voice_profile": {
      "type": "string",
      "minLength": 1
    },
    "renderer": {
      "type": "string",
      "enum": ["fake", "voicelayer-qwen3", "external-command"]
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "script": {
            "type": "string",
            "minLength": 1
          },
          "duration_seconds": {
            "type": "number",
            "minimum": 0
          },
          "notes": {
            "type": "string"
          }
        },
        "required": ["id", "title", "script"]
      }
    }
  },
  "required": ["voice_profile", "segments"],
  "if": {
    "properties": {
      "renderer": { "const": "voicelayer-qwen3" }
    },
    "required": ["renderer"]
  },
  "then": {
    "properties": {
      "voice_profile": { "minLength": 1 }
    },
    "required": ["voice_profile"]
  }
}
